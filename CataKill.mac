| --------------------------------------------------------------------------------------------
| SUB: GotoRecruiter
| --------------------------------------------------------------------------------------------
Sub GotoRecruiter
	/if (${Debugging}) /echo Sub GotoRecruiter Entry
	|----------- Ruined City of Dranik ------------
	/if (${Zone.ID} == ${RuinedCityofDranik}) {
		|---------------
		/if (!${Defined[Recruiter]}) {
			/declare Recruiter string outer Grand Historian Rygua
			/declare RecruiterLoc string outer ${Spawn[${Recruiter}].Y} ${Spawn[${Recruiter}].X} ${Spawn[${Recruiter}].Z}
		}
		|---------------
		|/removelev
		|----------------------------------------------
		|/echo {Spawn[${Recruiter}].Distance3D}=(${Spawn[${Recruiter}].Distance3D})
		:RecruiterDistanceCheck
		/if (${Spawn[${Recruiter}].Distance3D} <= 20) {
			/echo \agI am next to \am[\at${Recruiter}\am]\ay \ag getting an expedition...			
			/call GetExpedition
		} else {		
			|-------------
			/if (${Spawn[${Recruiter}].Distance3D} > 50) {
				/echo \agGoing to \ay[\ap${Recruiter}\ay] \ag to pick up an expedition...
				/call CheckInvis
				/squelch /e3bca /nav loc ${RecruiterLoc}
				/delay 1s
				/call NavToLoc3 ${RecruiterLoc}
				/delay 5
				|-------------
				|-------------
				/while (${Navigation.Active}) {
					/call SetLoc
					/call CheckStuck
					/delay 20
				}
				|-------------	
				/call GroupWait
				/if (${Me.XTarget[1].ID}) /call DoClearTargets
				/doevents	
				/goto :RecruiterDistanceCheck
			}
		}
		|----------------------------------------------
	}
	|----------- Ruined City of Dranik ------------

	/if (${Debugging}) /echo Sub GotoRecruiter Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GetExpedition (Called from GetExpedition)
| --------------------------------------------------------------------------------------------
Sub GetExpedition
	/if (${Debugging}) /echo Sub GetExpedition Entry

	/echo \agGettting an Expedition . . .

	:RequestExpedition
	/if (${Target.ID} != ${Spawn[${Recruiter}].ID}) /target id ${Spawn[${Recruiter}].ID}
	/delay 2s ${Target.ID} == ${Spawn[${Recruiter}].ID}
	/if (${Target.ID} != ${Spawn[${Recruiter}].ID}) /goto :RequestExpedition
	
	|----------------------------!
	/if (${Target.ID} == ${Spawn[${Recruiter}].ID}) {
		|--------------------------
		/delay 1s
		/say catacombs
		:WaitForCorrectExpedition
		|-------------------------------------------------------------------------------------------
		|----  DO NOT MESS WITH HE DELAYS BEFORE AND AFTER /DOEVETS OR IT WILL NOT PICKUP EVENT !!!!
		/delay 1s
		/doevents
		/delay 1s
		|----  DO NOT MESS WITH HE DELAYS BEFORE AND AFTER /DOEVETS OR IT WILL NOT PICKUP EVENT !!!!
		|-------------------------------------------------------------------------------------------
		/if (${DranikCExpedition}==0) /goto :WaitForCorrectExpedition
			
		|-------------------------------
		|--- Have an Expedition -- C !!!
		/if (!${CurrentExpedition.Length}==0 && ${CurrentExpedition.Find[Catacombs of Dranik]}) {
			/squelch /target clear
			/squelch /e3bcaa /keypress alt+z
			/echo \ayGoing to the expedition now . . . .
			|------------------------
			|--- Reset the Cycle Loop
			/call IniChange "Theme" "CompletedPathTo" "FALSE"
			/call ForceSpawnStepReset
			|------------------------
			/call GoToExpedition
		}
		|--- Have an Expedition -- C !!!
		|-------------------------------
	}
	|----------------------------

	/if (${Debugging}) /echo Sub GetExpedition Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GoToExpedition 
| --------------------------------------------------------------------------------------------
Sub GoToExpedition
	/if (${Debugging}) /echo Sub GoToExpedition Entry
	
	/echo \ayI am headed to: \am[\atCatacombs of Dranik (Caza)\am]\ag 
	|--- RESET INVIS !!!
	/if (${Me.Invis}) /dropinvis
	/delay 2s
	/call CheckInvis
	|--- RESET INVIS !!!
	
	|---------------------- INVIS VNAV !
	/call NavToLoc3 1019.45 -290.80 -75.26
	/delay 5
	/squelch /e3bca /nav loc 1019.45 -290.80 -75.26
	|---------------------- INVIS VNAV !
	
	|-------------
	/while (${Navigation.Active}) {
		/call SetLoc
		/call CheckStuck
		/delay 20
	}
	|-------------	
	/call Group2Me
	/call GroupWait
	/if (${Me.XTarget[1].ID}) /call DoClearTargets
	/doevents
	/squelch /e3bca /removelev
	/squelch /e3bca /doortarget CASTLESWITCH
	/delay 2s
	/squelch /e3bca /click left door
	/squelch /removelev
	/squelch /doortarget CASTLESWITCH
	/delay 2s
	/squelch /click left door
	/call Zoning
	
	/if (${Zone.ID} == ${CataCombC}) /call ResetBard

	/if (${Debugging}) /echo Sub GoToExpedition Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: CheckExpeditionStatus  
| --------------------------------------------------------------------------------------------------
Sub CheckExpeditionStatus
	/if (${Debugging}) /echo Sub CheckExpeditionStatus Entry

	|--------------------------------------------		
	|--- GRAB THE CURRENT EXPEDITIOn DATA
	|--------------------------------------------
	/call CheckInADungeon
	/call CheckHaveDranikCExp
	/varset CompletedPathTo ${Ini[${Settings},Theme,CompletedPathTo]}
	|/echo InADungeon=(${InADungeon}) | CurrentExpedition=(${CurrentExpedition}) | DranikCExpedition=(${DranikCExpedition}) | CompletedPathTo=(${CompletedPathTo}) 
	|--------------------------------------------
	
	|-----------------------------------------------------------------
	| We are still in an ative expedition and in the expedition zone !
	|-----------------------------------------------------------------
	/if (${DranikCExpedition}==1 && ${InADungeon}==1) /return
	|-----------------------------------------------------------------
	
	|-----------------------------------------------------------------------
	|--- Expedition Over, but i havenbet been booted out to Dranik yet !!!!
	|-----------------------------------------------------------------------
	/if (${DranikCExpedition}==0 && ${InADungeon}==1) {
		:WaitTillIGetBooted
		/echo \ay - Looks like our expedition is over, but we havent been booted yet, waiting !\ax
		/if (!${Me.Combat} && !${Me.XTarget[1].ID})  /delay 60s
		/goto :WaitTillIGetBooted
	}
	|-----------------------------------------------------------------------
	
	|-----------------------------------------------------------------------
	/if (${DranikCExpedition}==0 && ${InADungeon}==0) {
		/echo \ar-\ay I currently \arDO NOT HAVE\ay an expedition assigned to me !
		|-------------------
		/if ((${Zone.ID}==${RuinedCityofDranik}) && ${RepeatMission}) {
			|------------------------
			|--- Reset the Cycle Loop
			|------------------------
			/call IniChange "Theme" "CompletedPathTo" "FALSE"
			/call ForceSpawnStepReset
			|------------------------		
			/echo \ayI am headed to \am[\atGrand Historian Rygua\am]\ay to re-get an expedition.\ax
			/call GotoRecruiter
		}
		|-------------------		
		/if (!${RepeatMission}) /call CampInMarrs
	}
	|-----------------------------------------------------------------------
		
	/if (${Debugging}) /echo Sub CheckExpeditionStatus Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoClearTargets  
| --------------------------------------------------------------------------------------------
Sub DoClearTargets
	/if (${Debugging}) /echo Sub DoClearTargets Entry
	/if (${Me.XTarget[1].ID} || ${Target.ID}) {
		/delay 5
		|/keypress º
		/delay 5
		/ClearTargets
		:gotoloopkeepfighting
		/if (${Me.Sitting}) /stand
		/if (!${Target.ID} && ${Me.XTarget[1].ID}) {
			/squelch /e3bca /nav id ${Me.ID}			
			|/keypress º
			/delay 5
			/ClearTargets
			/delay 20
			/xtarget set 1 ${Me.Name}
			/delay 3
			/xtarget remove
			/delay 3
			}
		/if (${Target.ID} && !${Me.Combat}) {
			/squelch /e3bca /nav id ${Me.ID}
			|/keypress º
			/delay 5
			/ClearTargets
			/keypress esc
			/delay 20
			}
		/if (${Target.Type.Find[corpse]}) {
			/keypress esc
			/ClearTargets stick
			}
		/if (${Target.Distance.Int} > 20) /stick 15
		|-------------------------------------------------------------------
        /if (${Target.ID} && ${Me.Combat} && ${Target.Type.Equal[npc]}) {
			| --- Explosion of Spite
			/if (${SpawnCount[npc radius 50]} >2 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[749]} && ${DoBurns}) {
				/alt act 749
				/if (${DoBurns}) /quickburn
				/if (${DoBurns}) /longburn
				/delay 20
				/goto :gotoloopkeepfighting  
				}
			| --- Explosion of Hatred	
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[822]} && ${DoBurns}) {
				/alt act 822
				/if (${DoBurns}) /fullburn
				/delay 20
				/goto :gotoloopkeepfighting  
				}
			| --- Projection of Doom
			/if (${SpawnCount[npc radius 50]} >6 && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[3215]} && ${DoBurns}) /alt act 3215
			| --- EpicBurn
			/if (${SpawnCount[npc radius 50]} >4 && ${Spawn[npc radius 50].Aggressive} && ${DoBurns}) /epicburn
			| --- Vicious Bite of Chaos
			/if ((${Me.PctHPs} < 95) && ${Cast.Ready[825]} && ${DoBurns})  /alt act 825
			| --- Chattering Bones
			/if (${Cast.Ready[3822]} && ${DoBurns}) /alt act 3822
			| --- Encroaching Darkness
			/if ((${SpawnCount[npc radius 50]} <3) && ${Spawn[npc radius 50].Aggressive} && ${Cast.Ready[826]} && ${DoBurns}) {
				/squelch /e3bca /nav target
				/assistme
				/alt act 826
				}
            /delay 2s
            /if (${Debugging}) /echo DEBUG: KillMob: Combat Loop
			
            /goto :gotoloopkeepfighting 
        }
		|-------------------------------------------------------------------		
		/if (${Me.XTarget[1].ID} || ${Target.ID}) /goto :gotoloopkeepfighting
	}
	/delay 20
	/if (${Debugging}) /echo Sub DoClearTargets Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoSinglePull
| --------------------------------------------------------------------------------------------
Sub DoSinglePull(string Enemy)
	/if (${Debugging}) /echo DoSinglePull Sub Entry
	|-------------------------
	/call CheckCasting
	|-------------------------	
	/varset CampX ${Me.X}
	/varset CampY ${Me.Y}
	/varset CampZ ${Me.Z}
	/if (${Bool[${Enemy}]}) {
		/varset FarmMob ${Enemy}
		/if (${Debugging} && !${reportTarget}) {
			/echo Looking for: ${FarmMob}
			/varset reportTarget ${reportTarget.OriginalValue}
		}
	} else /if (!${reportTarget}) {
		/echo \arAttacking \ay[\apAnything I can get my grubby paws on\ay]\ar.
		/varset reportTarget ${reportTarget.OriginalValue}
		/if (${myTargetID} && !${Target.Type.Equal[corpse]}) {
		/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
		/if (!${UseCWTNHunterTankMode}) {
		/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) {
			/pet attack
			}
		/if (${Spawn[id ${Target.ID}].Distance} < 30 && ${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
		}
		/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
		/varcalc BackUpTimer (${BackUpTimer})+1
				/if (${BackUpTimer}>7) {
					/echo \ayHaving trouble getting to a target.. Attempting to get back on mesh.
					/if (${Debugging}) /echo Setting BackUpTimer Plus 1
					/call BackUp
					/varset BackUpTimer 0
				}
		/if (${AssistMe}) {
			/if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) killthis
			/squelch /e3bcg /nav id ${Me.ID}
			/squelch /e3bcg /target id ${Me.XTarget[1].ID}
			/timed 10 /squelch /e3bcg /pet attack
			/timed 15 /squelch /e3bcg /pet swarm
			/timed 20 /squelch /e3bcg /assistme
		}
		}

	}
	:findMob
	/if (${Debugging}) /echo FindMob DoSinglePull
	/if (${Target.Type.Equal[corpse]}) {
		/if (${Target.ID} == ${myTargetID}) /varset myTargetID 0
		/squelch /target clear
	}
	/if (${Window[RespawnWnd].Open}) /call GroupDeathChk
	/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}
	/if (${Debugging}) /echo \aymyTargetID has an ID: ${Spawn[id ${myTargetID}].ID} - is a corpse: ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} - I have an XTarget: !${Me.XTarget[1].ID}
	/if (!${Spawn[id ${myTargetID}].ID} || ${Spawn[id ${myTargetID}].Type.Equal[Corpse]} && !${Me.XTarget[1].ID} && !${Me.Casting.ID}) {
		/echo \ay"Looking for a target!"
		/varset myTargetID 0
		/call TargetShortest
		/delay 1s
		/echo \atMy Target: \ay[\ap${Spawn[id ${myTargetID}].Name}\ay]
	} else {
		/if (${Debugging}) /echo \ayI have an XTarget so I'm going to set that as my target.
		/if (${Me.XTarget[1].ID}) {
		/varset myTargetID ${Me.XTarget[1].ID}
		/if (${Debugging}) /echo CALL COMBAT
		/call Combat
		/if (${Debugging}) /echo END CALL COMBAT
		}
	}
	:navto
	/if (${Debugging}) /echo DoSinglePull NAVTO
	|/if (${Target.ID}) /squelch /target clear
	/if (${Spawn[${myTargetID}].Distance} > ${If[${PullAbilityRange},${PullAbilityRange},1]} && !${Target.Type.Equal[corpse]} && !${Me.XTarget[1].ID} && ${PullRequiresLineOfSight} || ${Spawn[${myTargetID}].Distance} > ${If[${PullAbilityRange},${PullAbilityRange},1]} && !${Target.Type.Equal[corpse]} && !${Me.XTarget[1].ID} && !${Spawn[${myTargetID}].LineOfSight}) {
		/if (!${Spawn[${myTargetID}].ID}) {
			/squelch /target clear
			/if (${Debugging}) /echo \ar My target ID was null, so I'm returning out of the sub. 
			/return
		}
		/varset BackUpTimer 0
		/echo \agNavigating to: \ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agID: \ay[\ap${myTargetID}\ay] \agDistance: \ay[\ap${Spawn[${myTargetID}].Distance}\ay]
		/if (${Debugging}) /echo \ayNavigating to ${Spawn[${myTargetID}].Name} ID: ${myTargetID} Distance: ${Spawn[${myTargetID}].Distance} > ${If[${PullAbilityRange},${PullAbilityRange},30]} - Line of Sight: ${Spawn[${myTargetID}].LineOfSight}
		/call WaitNav ${myTargetID}
		/delay 10
		/if (${Debugging}) /echo Navigating to the enemy.
		/call SetLoc
		/call CheckStuck
		/delay 5
		/goto :navto
	} else /if (!${Target.ID} || ${Target.ID} != ${myTargetID} && ${Target.ID} != ${Me.ID} && ${myTargetID} != 0 && !${Me.XTarget[1].ID}) {
		/target id ${myTargetID}
		/if (${Navigation.Active}) /nav stop
	}
	/delay 5
	/docommand ${If[${PullAbilityRange}>30,/stop,/stick moveback uw 10]}
	|-----------------------------------------------
	/if (${Debugging}) /echo DoSinglePull Sub Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: TargetShortest
| --------------------------------------------------------------------------------------------
Sub TargetShortest
	/if (${Debugging}) /echo Sub TargetShortest Entry
	/if (${UseClickBuffs}) /call Clickies_Buffs
	/declare MobsInRadius 	int 	local 	${SpawnCount[npc noalert 1 targetable radius ${CampRadius} zradius ${ZRadius} alert 10]}
	

	|- Makes scanning in big zones super efficient.
	/if (${MobsInRadius} > 5) {
		/varset MobsInRadius 5
	}
	/declare MobCounter 	int 	local 	0
	/declare MobID 			int 	local 	0
	/declare PathLength		float	local	0
	/declare MobIDDistance	float	local	0
	/declare PathCount		int		local	1
	/declare PathShortest	int 	local 	0
	/declare MobIDValid		int		local	0
	/if (${Resting}) /return

	/varset myTargetID 0
	/if (${MobsInRadius}) {
		/for MobCounter 1 to ${MobsInRadius}
		/varset MobID ${NearestSpawn[${MobCounter},npc targetable radius ${CampRadius} zradius ${ZRadius} alert 10 noalert 1].ID}

		/if (${Select[${Spawn[ID ${MobID}].Type},AURA,BANNER,CAMPFIRE,CORPSE,CHEST,ITEM,TRIGGER,TRAP,TIMER,MOUNT,MERCENARY,OBJECT]} && !${Ini[${MobIgnore},${Zone.ShortName},Ignored].Find[ID ${MobID}]}) /continue
		/if (${Spawn[ID ${MobID}].Surname.Length}) /continue
		
		|------- HARD CODED EXCEPTIONS
		|/if (${Spawn[ID ${MobID}].CleanName.Equal[a hatchling]} || ${Spawn[ID ${MobID}].CleanName.Equal[a creaking crate]} || ${Spawn[ID ${MobID}].CleanName.Equal[a hollow tree]} || ${Spawn[ID ${MobID}].CleanName.Equal[a petrified colossal tree]}) {
		|/continue
		|}
		|------- HARD CODED EXCEPTIONS

		/varset MobIDValid 0
		/varset PathLength ${Navigation.PathLength[id ${MobID}]}
		/if (${PathLength} > 0) {
			/if (${PathCount}==1) {
				/varset myTargetID ${MobID}
				/varset PathShortest ${PathLength}
			} else /if (${PathLength} <= ${PathShortest}) {
				/varset myTargetID ${MobID}
				/varset PathShortest ${PathLength}
			}
			/varcalc PathCount ${PathCount}+1 
		}
		
		/next MobCounter
		/if (${myTargetID}) /message \agPulling \ay[\ap${Spawn[${myTargetID}].CleanName}\ay] \agNPCID:\ay[\ap${myTargetID}\ay] \awat \ay[\at${PathShortest}\ay] \awfeet.
		/varset Announce FALSE
		/varset notkillable 0
	} else {
		/varset myTargetID 0
		/delay 5s ${Me.XTarget} == 0
		/if (!${Me.XTarget}) {
			/if (!${Announce}) {
				/message No more mobs to pull, lets Wait for Respawn!
				/varset Announce TRUE
			}
			/varset notkillable 0
			/if (${Me.Standing} && !${Navigation.Active}) /sit
		}
		/if (${Me.XTarget}) /return
	}
	/delay 1
	/if (${Debugging}) /echo Sub TargetShortest exit
	/varcalc BackUpTimer (${BackUpTimer})+1
	/if (${Debugging}) /echo Setting BackUpTimer +1 to ${BackUpTimer}
	/if (${Debugging} && ${BackUpTimer}>1) /echo \arCould Be Stuck ${BackUpTimer}
	/if (${BackUpTimer}>10) {
	/echo \ayHaving trouble getting to a target.. Attempting to get back on mesh.
	/if (${Debugging}) /echo Setting BackUpTimer Plus 1
	/call BackUp
	/varset BackUpTimer 0
	}
	/if (${Debugging}) /echo Sub TargetShortest Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Combat
| --------------------------------------------------------------------------------------------
Sub Combat
	/if (${Debugging}) /echo Sub Combat Entry
	/if (${Target.ID} && (${Target.Type.Equal[npc]} || ${Target.Type.Equal[pet]})) {
		/if (${Navigation.Active}) /squelch /nav stop
		/stick uw loose moveback 8 
		|/setchattitle Killing ${Target.CleanName}
		/if (${AssistMe} && !${UseCWTN} && !${UseRGMercs}) {
			/if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) killthis
			/squelch /e3bcg /nav id ${Me.ID}
			/squelch /e3bcg /target id ${Me.XTarget[1].ID}
			/timed 10 /squelch /e3bcg /pet attack
			/timed 15 /squelch /e3bcg /pet swarm
			/timed 20 /squelch /e3bcg /assistme
		}
		/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) {
			/pet attack
			}
		/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
		/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}									 
		:waitTillDead
	
		/if (${Target.ID} && ${Me.CombatState.Equal[Combat]} && (${Target.Type.Equal[npc]} || ${Target.Type.Equal[pet]})) {
			/if (!${Me.Combat}) {
			/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
			/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) {
			/pet attack
			}
			/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			}
			/if (${Me.Class.CanCast} && ${UseCastSpells}) {
				/if (!${Defined[i]}) {
					/declare i int local 0
				}
				/if (!${Me.Casting.ID}) {
					/for i 1 to ${Me.NumGems}
						/if (!${Me.XTarget}) /break
						/if (${Me.Gem[${i}].ID}) {
							/if (${Me.Gem[${i}].TargetType.Equal[Single]} && ${Me.Gem[${i}].SpellType.Equal[Detrimental]} !${Target.Buff[${Me.Gem[${i}].Name}].ID}) {
								/cast ${i}
								/delay 3s ${Me.Casting.ID}
								/echo \agCasting \am${Me.Gem[${i}]} \aw--> \ar${Target.CleanName}
								/delay ${Math.Calc[${Me.Gem[${i}].CastTime.TotalSeconds}+2].Int}s !${Me.Casting.ID}
							}
						}
					/next i
				}
			}
			
			/delay 10
			/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			/goto :waitTillDead
			/varset notkillable 0
		} else /if (${Target.Type.Equal[corpse]}) {
			/target clear
			/varset myTargetID 0
		}
	} else /if (${Me.XTarget[1].ID}) {
		/if (${Spawn[id ${Me.XTarget[1].ID} radius 30 zradius 50].ID} && ${Spawn[id ${Me.XTarget[1].ID} radius 30 zradius 50].LineOfSight}) {
			/if (${Navigation.Active}) /nav stop
			/if (${AssistMe}) {
                /if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) target XTarget ${Spawn[id ${Me.XTarget[1].ID}].Name}
                /squelch /e3bcg /target id ${Me.XTarget[1].ID}
            } else {
                /target id ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Me.XTarget[1].ID}].Distance} > 30) /squelch /nav id ${Me.XTarget[1].ID}
				/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) {
					/pet attack
					}
				/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
            }
			|/setchattitle Handling add, ${Spawn[${Me.XTarget[1].ID}].CleanName}
		} else /if (${Spawn[id ${Me.XTarget[1].ID}].Distance} > 30 || !${Spawn[id ${Me.XTarget[1].ID} radius 30 zradius 50].LineOfSight}) {
			/squelch /nav id ${Me.XTarget[1].ID}
			/if (!${Me.CombatState.Equal[Combat]}) {
                /if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) target me and stick (DoSinglePull1).
                /squelch /e3bcg /target id ${Me.ID}
                /delay 5
                /squelch /e3bcg /stick 10 loose moveback uw
            }
			|/setchattitle Navigating to add ${Spawn[id ${Me.XTarget[1].ID}].CleanName}
			/varset BackUpTimer 0
			/while (${Spawn[${Me.XTarget[1].ID}].Distance} > 30) {
				/if (!${Navigation.Active}) {
					/squelch /nav id ${Me.XTarget[1].ID}
					/if (!${Me.CombatState.Equal[Combat]}) {
                        /if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) target me and stick (DoSinglePull2).
                        /squelch /e3bcg /target id ${Me.ID}
                        /delay 5
                        /squelch /e3bcg /stick 10 loose moveback uw
                    }
                }
                /delay 10
				/if (!${courseCorrection}) {
					/squelch /nav id ${Me.XTarget[1].ID}
					/varset courseCorrection ${courseCorrection.OriginalValue}
				}
			/call SetLoc
			/call CheckStuck
			/call GMCheck
			}
		}
            /if (${AssistMe} && !${UseCWTN} && !${UseRGMercs}) {
                /if (${Debugging}) /e3bcg (Line: ${Macro.CurLine}) killthis
				/squelch /e3bcg /nav id ${Me.ID}
                /squelch /e3bcg /target id ${Me.XTarget[1].ID}
                /timed 10 /squelch /e3bcg /pet attack
                /timed 15 /squelch /e3bcg /pet swarm
                /timed 20 /squelch /e3bcg /assistme
            }
		/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
		/if (${Select[${Me.Class.ShortName},SHD,MAG,NEC,BST,SHM,ENC,DRU]} && ${Me.Pet.ID}) {
			/pet attack
			}
		/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
		|/setchattitle Killing ${Target.CleanName}
		/goto :waitTillDead
		/varset notkillable 0
	}
	/if (${Debugging}) /echo Sub Combat Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SwarmPullStepMove_1   Receive: SpawnPull_Step from Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------------
Sub SwarmPullStepMove_1(string SpawnPull_Step)
	/declare x 						int 	local 	${SpawnPull_Step}
	/declare TempSpawnPull_Loc		string 	local	NULL
	
	/if (${Debugging}) /echo Sub SwarmPullStepMove_1 Entry
	/if (${Debugging}) /echo SpawnPull_Loc=(${SpawnPull_Loc}) | SpawnPull_Step=(${SpawnPull_Step})
	
	/message ==================================================================
	/message \ag+++\ax \ayStarting \arSpawnPull \atPathTo \agCycle:\ax \ao...\ax \arLets go !\ax
	/message ==================================================================	
	
	|----------------------------------------------------------------------------------------------
    /for x ${SpawnPull_Step} to ${LocalStepArray_${Zone.ShortName}_1.Size}
		/varset TempSpawnPull_Loc ${LocalStepArray_${Zone.ShortName}_1[1,${x}]}
		
		|-----------------------------
		/if (${TempSpawnPull_Loc.Equal[NULL]}) {
			/echo \ar The Catacomb steps did not load correctly, reloading !
			/call DoSwarmPull_PathTo
			/delay 10
		}
		|-----------------------------
		
		|------------------------------------------
		/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
		}		
		|------------------------------------------		
		
		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/echo \at - Calling the group to me before moving to the next step . . . . 
		/call GroupWait
		/delay 1s
		|------------------------------------------
		
		|-------------------------
		/call CheckCasting
		|-------------------------	

		|-----------------------------------------------
		|/echo \arSwarmPullStepMove: \ayTempSpawnPull_Loc=(${TempSpawnPull_Loc})
		|-----------------------------------------------
		/if (${TempSpawnPull_Loc.Length}>0) {
			/echo \agNext location to Nav to is: \aySTEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_1.Size}\ay] Coordinates: [\am${TempSpawnPull_Loc}\ay]
			|--------------------------------------------------------------
			|/echo \agARRAY RETURNED DATA for step \ay[${x}]\ag: TempSpawnPull_Loc=(\am${TempSpawnPull_Loc})
			|--------------------------------------------------------------
			/if (!${Me.Combat} && !${Me.XTarget[1].ID} && !${Target.ID}) {				
				|----------------------------------------------
				|-- Just nav to loc, using NavToLoc function will cause you to engage mobs along the path !
				/nav loc ${TempSpawnPull_Loc}
				|----------------------------------------------
				/squelch /e3bca /nav loc ${TempSpawnPull_Loc}
			}
			|--------------------------------------------------------------
			/e3bca /nav loc ${TempSpawnPull_Loc}
			/delay 5
			/while (${Navigation.Active}) {
				/call SetLoc
				/call CheckStuck
				/delay 5
			}
			/squelch /e3bca /nav id ${Me.ID}
			/delay 5
			|----------------------------------------------------------		

			|-------------------------------------------------------------------------------------------------------
			|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
			|-------------------------------------------------------------------------------------------------------
			/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
			/call IniChange "Theme" "LastSwarmed_Step" ${x}
			|-------------------------------------------------------------------------------------------------------

			|---------------------------------------------------------------
			| Use the DoClearTargets for SPawnPull system instead, of COMBAT
			|---------------------------------------------------------------
			/call DoClearTargets
			/doevents
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.
		/if (${LootCorpse} && !${Me.XTarget[1].ID}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------
		/call CheckExpeditionStatus
    /next x
	|----------------------------------------------------------------------------------------------
	/message ==================================================================
	/echo /atCompleted all SwarmPull "PathTo" steps./ax
	/echo /atUpdating (\ay${Settings})\ax INI file with PathTo completion./ax
	/call IniChange "Theme" "CompletedPathTo" "TRUE"
	/call ForceSpawnStepReset	
	/echo /ayStarting Main Cycle Run !!!/ax
	/message ==================================================================
	/delay 3s
	|------------------------------------------------------
	/if (!${BiggerSwarms}) {
		/call DoSwarmPull_MainLoop
	} else {
		/call DoSwarmPull_MainLoop_Bigger
	}
	|------------------------------------------------------
	/delay 10
		
	/if (${Debugging}) /echo Sub SwarmPullStepMove_1 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: SwarmPullStepMove_2   Receive: SpawnPull_Step from Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------------
Sub SwarmPullStepMove_2(string SpawnPull_Step)
	/declare x 						int 	local 	${SpawnPull_Step}
	/declare TempSpawnPull_Loc		string 	local	NULL
	/declare CampReturnLoc			string	local	1905.66 336.42 -134.67
	
	/if (${Debugging}) /echo Sub SwarmPullStepMove_2 Entry
	/if (${Debugging}) /echo SpawnPull_Loc=(${SpawnPull_Loc}) | SpawnPull_Step=(${SpawnPull_Step})
	
	|-- MOVE TO CAMP
	/squelch /e3bca /nav loc ${CampReturnLoc}
	/delay 1s
	/call NavToLoc2 ${CampReturnLoc}
	/delay 5
	
	:MainLoopCycle
	/delay 1s
	/message ==================================================================
	/message \ag+++\ax \ayStarting \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \arLets go !\ax
	/message ==================================================================
	/delay 3s
	|-------------------------------------------------------------------------------------------------------
    /for x ${SpawnPull_Step} to ${LocalStepArray_${Zone.ShortName}_2.Size}
		/varset TempSpawnPull_Loc ${LocalStepArray_${Zone.ShortName}_2[1,${x}]}
		
		|-----------------------------
		/if (${TempSpawnPull_Loc.Equal[NULL]}) {
			/echo \ar The Catacomb steps did not load correctly, reloading !
			/call DoSwarmPull_MainLoop
			/delay 10
		}
		|-----------------------------
		
		|------------------------------------------
		/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
			/call GroupDeathChk
			/call GroupManaChk
			/call GroupEndChk
		}		
		|------------------------------------------		
		
		|------------------------------------------
		| Move group to me before next step
		|------------------------------------------
		/echo \at - Calling the group to me before moving to the next step . . . . 
		/call GroupWait
		/delay 1s
		|------------------------------------------
		
		|-------------------------
		/call CheckCasting
		|-------------------------
		
		|-----------------------------------------------
		|/echo \arSwarmPullStepMove: \ayTempSpawnPull_Loc=(${TempSpawnPull_Loc})
		|-----------------------------------------------
		/if (${TempSpawnPull_Loc.Length}>0) {
			/echo \agNext location to Nav to is: \aySTEP: \ay[\am${x}\ay] of \ay[\am${LocalStepArray_${Zone.ShortName}_2.Size}\ay] Coordinates: [\am${TempSpawnPull_Loc}\ay]
			|--------------------------------------------------------------
			|/echo \agARRAY RETURNED DATA for step \ay[${x}]\ag: TempSpawnPull_Loc=(\am${TempSpawnPull_Loc})
			|--------------------------------------------------------------
			/if (!${Me.Combat} && !${Me.XTarget[1].ID} && !${Target.ID}) {				
				|----------------------------------------------
				|-- Just nav to loc, using NavToLoc function will cause you to engage mobs along the path !
				/nav loc ${TempSpawnPull_Loc}
				|----------------------------------------------
				/squelch /e3bca /nav loc ${TempSpawnPull_Loc}
			}
			|--------------------------------------------------------------
			/e3bca /nav loc ${TempSpawnPull_Loc}
			/delay 5
			/while (${Navigation.Active}) {
				/call SetLoc
				/call CheckStuck
				/delay 5
			}
			/squelch /e3bca /nav id ${Me.ID}
			/delay 5
			|----------------------------------------------------------		

			|-------------------------------------------------------------------------------------------------------
			|- WRITE: LastSwarmed_Dungeon and LastSwarmed_Step to ini file, to pickup at this point if we break macro.
			|-------------------------------------------------------------------------------------------------------
			/call IniChange "Theme" "LastSwarmed_Dungeon" ${Zone.ShortName}
			/call IniChange "Theme" "LastSwarmed_Step" ${x}
			|-------------------------------------------------------------------------------------------------------

			|---------------------------------------------------------------
			| Use the DoClearTargets for SPawnPull system instead, of COMBAT
			|---------------------------------------------------------------
			/call DoClearTargets
			/doevents
			/delay 10
		}
		|-----------------------------------------------
		| Before we go to next step ...   ECheck if we should loot Corpses.
		/if (${LootCorpse} && !${Me.XTarget[1].ID}) /call CheckForCorpses
		| Before we go to next step ...   EXIT the loop if we have mission success !
		|-----------------------------------------------
		/call CheckExpeditionStatus
    /next x
	|-------------------------------------------------------------------------------------------------------

	| --- NAV TO CampReturnLoc
	/message ==================================================================
	/message \ag+++\ax \aoCompleted \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \atRETURNING TO CAMP !!!\ax
	/message ==================================================================
	/squelch /e3bca /nav loc ${CampReturnLoc}
	/delay 1s
	/call NavToLoc2 ${CampReturnLoc}
	/delay 5
	
	|------------------------------------------
	/if (!${Me.XTarget[1].ID} && ${CheckBots}) {
		/call GroupDeathChk
		/call GroupManaChk
		/call GroupEndChk
	}		
	|------------------------------------------		
	
	/message ==================================================================
	/message \ag+++\ax \aoCompleted \arSpawnPull \atMainLoop \agCycle:\ax \ao...\ax \agLets do it again !!!\ax
	/message ==================================================================
	/delay 3s
	
	/goto :MainLoopCycle
	
	|----------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo Sub SwarmPullStepMove_2 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Go2LastSwarmLoc     ( Always Call This to pick up From LastSwarmed_Step )
| --------------------------------------------------------------------------------------------
Sub Go2LastSwarmLoc
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Entry
	|------------------------------------------------------------------------------------------------------------
	|- READ:  LastSwarmed_Dungeon and LastSwarmed_Step from ini file, to pickup at this point if restarted macro.
	|------------------------------------------------------------------------------------------------------------
	/varset LastSwarmed_Dungeon ${Ini[${Settings},Theme,LastSwarmed_Dungeon]}
	/varset LastSwarmed_Step ${Ini[${Settings},Theme,LastSwarmed_Step]}
	|-------------------------------------------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ayLastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})	
	|-------------------------------------------------------------------------------------------------------
	/if (${Debugging}) /echo LastSwarmed_Dungeon=(${LastSwarmed_Dungeon}) | LastSwarmed_Step=(${LastSwarmed_Step})	
	/echo \agThe last known spawn pull \aySTEP\ag is: \ay[\am${LastSwarmed_Step}\ay]

	|--------------------------------------------------------------------------------------------------------------------------
	| - Call the SwarmPullStepMove function and pass the location and step from INI file 
	| - (The Array Values have already defined from DoSwarmPull)
	| -
	| If we are in same dungeon, pickup from LastSwarmed_Loc .. else..  run the path fresh !
	| SwarmPullStepMove will pick up the path in a loop where the step number will change X in the loop !
	|--------------------------------------------------------------------------------------------------------------------------
	|/echo {Zone.ShortName}=(${Zone.ShortName}) | {Ini.File.Zone.Name}=(${LastSwarmed_Dungeon}) 
	|-----------------------------------------------------------------------
	| Change values to pass STEP 1 if we arent in the last recorded dungeon.
	|-----------------------------------------------------------------------
	/if (!${Zone.ShortName.Equal[${LastSwarmed_Dungeon}]}) {
		/call ForceSpawnStepReset
	}
	|-----------------------------------------------------------------------
	|/echo \arGo2LastSwarmLoc: \ay/call SwarmPullStepMove ${LastSwarmed_Step}
	|-----------------------------------------------------------------------
	
	|-----------------------------------
	|- Retrieve the last mission results
	|-----------------------------------
	/varset CompletedPathTo ${Ini[${Settings},Theme,CompletedPathTo]}
	|-----------------------------------
	/if (!${CompletedPathTo}) {
		/call SwarmPullStepMove_1 ${LastSwarmed_Step}
	} else {
		/call SwarmPullStepMove_2 ${LastSwarmed_Step}		
	}
	|-----------------------------------------------------------------------

	|--------------------------------------------------------------------------------------------------------------------------	
	/if (${Debugging}) /echo Sub Go2LastSwarmLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------------
| SUB: ForceSpawnStepReset
| --------------------------------------------------------------------------------------------------
Sub ForceSpawnStepReset
/if (${Debugging}) /echo Sub ForceSpawnStepReset Entry

	/echo \arForcing LastSwarmed_Step reset to step \ay(\at1\ay)

	|----------------------------------------------------------
	| -- Write STEP 1 to the ini file since we want to set our initial first step for that zone.
	|------------------------------------------
	/call IniChange "Theme" "LastSwarmed_Step" 1
	/delay 20
	|------------------------------------------

/if (${Debugging}) /echo Sub ForceSpawnStepReset Exit
/return
| --------------------------------------------------------------------------------------------------

