Sub Event_Catacomb_A
	/echo \ayYou have received an expedition for \am[\atCatacombs of Dranik (Azia)\am]\ar - BOO - Leaving !\ax
	/squelch /e3bcaa /dzquit 
	/delay 1s
	/varset DranikCExpedition 0
	/varset CurrentExpedition NULL
	/delay 1s
	|/echo DranikCExpedition=(${DranikCExpedition}) | CurrentExpedition=(${CurrentExpedition})
	/echo \ar - WRONG EXPEDITION !
	/say catacombs
	/doevents flush Catacomb_A
/return
