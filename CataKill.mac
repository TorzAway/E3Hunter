|--------------------------------------------------------
| INIChange
|--------------------------------------------------------
Sub INIChange(Section,Key,Value)
/if (${Debugging}) /echo Sub INIChange Entry
	/ini "${Settings}" "${Section}" "${Key}" "${Value}"
/if (${Debugging}) /echo Sub INIChange Exit	
/return
|--------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckStuck
| --------------------------------------------------------------------------------------------
Sub CheckStuck
	/if (${Debugging}) /echo Sub CheckStuck Entry
	/if (${Me.Stunned} || !${Navigation.Active}) /return
	/if (${StuckSpamTrigger}) /return 
	|/echo ${Math.Distance[${OutY1},${OutX1}]}
	/if (${Math.Distance[${OutY1},${OutX1}]} < 20) {
		/varcalc StuckCountOut (${StuckCountOut})+1
		/if (${StuckCountOut}>6) /echo \arStuck ${StuckCountOut}
		/if (${Me.ActiveDisc.Name.Equal[Frenzied Resolve Discipline]}) /stopdisc
		/if (${StuckCountOut}>6) {
			/call doorclick 
			/if (${UseBeep}) {
			/beep
			/delay 1
			/beep
			}
			/call doorclick 
			}
		/varset StuckSpamTrigger 1
	} else { 
		/varset StuckCountOut 0
		}
	/if (${StuckCountOut}>=8) {
				/echo \ayThink I'm stuck... \agAttempting to get unstuck...
				/call Stuck
				/varset StuckCountOut 0				
		}	
	/if (${Debugging}) /echo Sub CheckStuck Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Stuck
| --------------------------------------------------------------------------------------------
sub Stuck
/if (${Debugging}) /echo Sub Stuck Entry
/if (${StuckSwitch}) {
	/if (${Debugging}) /echo Hide Corpse STUCK
	/hidecorpse all
	/call BackUp
	/varset myTargetID 0			
	/varset StuckSwitch 0
	/varset StuckCountOut 0
	} else {
		/call DoorClick
		/varset StuckSwitch 1
		/varset StuckCountOut 0
		/varset courseCorrection 0
		/if (${Debugging}) /echo Hide Corpse STUCK
		/hidecorpse none
		}
/if (${Debugging}) /echo Sub Stuck Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: BackUp
| --------------------------------------------------------------------------------------------
Sub BackUp
	/if (${Debugging}) /echo Sub Backup Entry
    /declare strafedir string local
	/target clear
	|/call DoorClick
	/if (${Navigation.Active}) /nav pause
	/if (${Me.FeetWet}) {
		/keypress down hold 
		/delay 10
		/keypress PAGE_UP hold
		/delay 20
		/keypress up hold
		/keypress right hold
		/delay 10
		/keypress left 
		/keypress down
		/keypress PAGE_DOWN
	}
	/keypress back hold
	/delay 20
	/varset myTargetID 0
	/keypress back
	/if (${Math.Rand[2]}) {
		/varset strafedir STRAFE_LEFT
	} else {
		/varset strafedir STRAFE_RIGHT
	}
	/keypress ${strafedir} hold
	/delay 20
	/keypress ${strafedir}
	/delay 10
	/keypress forward hold
	/delay 10
	/keypress forward
	|/if (!${Navigation.Active}) /nav pause
	/if (${Debugging}) /echo Sub Backup Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: SetLoc
| --------------------------------------------------------------------------------------------
sub SetLoc
	/if (${Debugging}) /echo Sub SetLoc Entry
	/if (${StuckSpamTimerSet} || !${Navigation.Active}) /return 
	/varset OutX1 ${Me.X}
    /varset OutY1 ${Me.Y}
	/varset StuckSpamTimerSet 5s
	|----------------------------------------------------------------
	|/echo (${Int[${Me.X}]}==${OutX1}) && (${Int[${Me.Y}]}==${OutY1})
	|----------------------------------------------------------------
	/if (${Debugging}) /echo Sub SetLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupWait
| --------------------------------------------------------------------------------------------
Sub GroupWait
/if (${Debugging}) /echo Sub GroupWait Entry
:WaitForGroup
/if (${Me.XTarget[1].ID}) {
	/if (${Navigation.Active}) /nav stop
	/call DoSinglePull
	/goto :WaitForGroup
}
/echo \ayWaiting for the group. . .

/if (${Debugging}) /echo ${Group.Member[1].CleanName}:(${Group.Member[1].Distance}) ${Group.Member[2].CleanName}:(${Group.Member[2].Distance}) ${Group.Member[3].CleanName}:(${Group.Member[3].Distance}) ${Group.Member[4].CleanName}:(${Group.Member[4].Distance}) ${Group.Member[5].CleanName}:(${Group.Member[5].Distance})

    /while ((${Group.Member[1].Distance} > 40) || (${Group.Member[2].Distance} > 40) || (${Group.Member[3].Distance} > 40) || (${Group.Member[4].Distance} > 40) || (${Group.Member[5].Distance} > 40) || (${Group.Member[6].Distance} > 40)) {
        /echo \aywaiting for the group, timer ${GroupWaitTimer}.\ax
		/e3bca /stand
		/e3bca /nav id ${Me.ID}
        /delay 5s
		/varcalc GroupWaitTimer (${GroupWaitTimer})+1
		/call GroupWaitTimer
		/goto :WaitForGroup
	}
	/varset GroupWaitTimer 0
	/echo \ay. . . my group is now here.\ax
	/if (${Debugging}) /echo Sub GroupWait Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupWaitTimer
| --------------------------------------------------------------------------------------------
Sub GroupWaitTimer
	/if (${Debugging}) /echo Sub GroupWaitTimer Entry
	/if (${GroupWaitTimer}==12) /varset GroupWaitTimer 0
	/if (${GroupWaitTimer}==10) {
		/echo \ayA Group Member might be stuck!
		/squelch /e3bcaa /stand
		/squelch /e3bcaa /removelev
		/squelch /e3bcaa /moveto loc ${Me.Y} ${Me.X} ${Me.Z}
		/squelch /e3bcaa /keypress back hold
		/delay 3s
		/squelch /e3bcaa /keypress back
	}
	/if (${GroupWaitTimer}==11) {
		/echo \ayA Group Member is stuck!
		/squelch /e3bcaa /moveto loc ${Me.Y} ${Me.X} ${Me.Z}
		/squelch /e3bcaa /keypress forward hold
		/delay 2s
		/squelch /e3bcaa /keypress forward
		/delay 2s	
	}
	/if (${Debugging}) /echo Sub GroupWaitTimer Exit
/return GroupWaitTimer
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckCasting
| --------------------------------------------------------------------------------------------
Sub CheckCasting
	/if (${Debugging}) /echo Sub CheckCasting Entry

	|-------------------------
	:CheckCastingNow
	/if (${Me.Casting.ID}) {
		/echo \ag-- Waiting to stop casting.
		/delay 1s !${Me.Casting.ID}
		/goto :CheckCastingNow
		/echo \ag-- I am done casting.
		/delay 1s
	}
	|-------------------------

	/if (${Debugging}) /echo Sub CheckCasting Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GMCheck
| --------------------------------------------------------------------------------------------
Sub GMCheck
/if (${Debugging}) /echo Sub GMCheck Entry
/if (${Spawn[gm].ID} && ${AFKGM}) {
				/echo \ar WARNING GM nearby!
				/if (${UseBeep}) /beep
				|------------------------------------------------
				|--- DON't Call Gmmode, just call FinishAdventure
				|/call GMMode
				/call FinishAdventure
				|------------------------------------------------
				}
/if (${Debugging}) /echo Sub GMCheck Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: ResetBard
| --------------------------------------------------------------------------------------------
Sub ResetBard
	/if (${Debugging}) /echo Sub ResetBard Entry
	/echo \agPerforming Bard Reset !\ax
	
	/declare x 					int 	local	1
	
		/for x 1 to ${Group.Members} 
			/if (${Group.Member[${x}].Class.ShortName.Equal[BRD]}) {
				/echo \ayResetting E3 [\atBRD\ay] MELODY for [\am${Group.Member[${x}].CleanName}\ay].
				|------------------------				
				/squelch /e3bct ${Group.Member[${x}].CleanName} /mono E3
				/delay 3s
			}		
		/next x

	/if (${Debugging}) /echo Sub ResetBard Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckInvis
| --------------------------------------------------------------------------------------------
Sub CheckInvis
	/if (${Debugging}) /echo Sub CheckInvis Entry
	
	/declare x 					int 	local	0
	
	|----------------------------------------------------------------------------
	|--- REFERENCE ----
	|----------------------------------------------------------------------------
	|/squelch /e3bcg /alt act 280 	; -- Group Perfected Invisibility to Undead
	|/squelch /e3bcg /alt act 8301 	; -- Improved Natural Invisibility
	|/squelch /e3bcg /alt act 1212 	; -- Group Perfected Invisibility to Undead
	|/squelch /e3bcg /alt act 630 	; -- Group Silent Presence
	|/squelch /e3bcg /alt act 531 	; -- Cloak of Shadows
	|/squelch /e3bcg /alt act 518 	; -- Shared Camouflage
	|/squelch /e3bcg /alt act 1210 	; -- Group Perfect Invisibility
	|/squelch /e3bcg /alt act 231 	; -- Shauri's Sonorious Clouding
	|----------------------------------------------------------------------------

	/if (!${Me.Invis}) {
		/squelch /e3bcg /alt act 280
		/squelch /e3bcg /alt act 8301
		/squelch /e3bcg /alt act 1212
		/squelch /e3bcg /alt act 630
		/squelch /e3bcg /alt act 531
		/squelch /e3bcg /alt act 518
		/squelch /e3bcg /alt act 1210
		/squelch /e3bcg /alt act 231
		/delay 5s
	}
	
	|:CheckBrdInvisNow
	/if (!${Me.Invis}) {
		/echo \arNeed to make myself invisible!
		|-----------------------------		
		/for x 1 to ${Group.Members} 
			/if (${Group.Member[${x}].Class.ShortName.Equal[BRD]}) {
				/echo \ay[\am${Group.Member[${x}].CleanName}\ay] is a [\atBRD\ay], making them sing invis !				
				|------------------------				
				/squelch /e3bct ${Group.Member[${x}].CleanName} /playmelody stop
				/delay 1s
				/squelch /e3bct ${Group.Member[${x}].CleanName} /memspell ${BRDTravelSongSlot} ${BRDTravelSong}
				/delay 3s
				:CheckBrdInvisNow
				/if (!${Me.Invis}) {				
					/squelch /e3bct ${Group.Member[${x}].CleanName} /cast ${BRDTravelSongSlot} ${BRDTravelSong}
					/delay 3s
					/echo \agWaiting for invis to kick in .....
					/delay 5s ${Me.Invis}
					/goto :CheckBrdInvisNow
				}
				|------------------------
			}		
		/next x
		|-----------------------------
		/if (${Me.Class.ShortName.Equal[NEC]} || ${Me.Class.ShortName.Equal[SHD]}) {
			/if (${Me.AltAbility[Cloak of Shadows]}) {
				/alt act ${Me.AltAbility[Cloak of Shadows]}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else /if (${Me.ItemReady[Circlet of Shadows]} && !${Me.Buff[Gather Shadows].ID}) {
            	/useitem Circlet of Shadows
            	/delay 1s
            	/echo \agActivating \ay[\apCirclet of Shadows\ay]
            	/delay 1s !${Me.ItemReady[Circlet of Shadows]}
        	} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doens't have invis!
			}
		} else /if (${Me.Class.ShortName.Equal[BRD]}) {
			/if (${Me.AltAbility[Shauri's Sonorous Clouding]}) {
				/alt act ${Me.AltAbility[Shauri's Sonorous Clouding]}
				/delay 5
				/removelev
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			}
		} else /if (${Me.Class.ShortName.Equal[MAG]} || ${Me.Class.ShortName.Equal[WIZ]} || ${Me.Class.ShortName.Equal[ENC]}) {
			/if (${Me.AltAbility[Perfected Invisibility]}) {
				/alt act ${Me.AltAbility[Perfected Invisibility]}
			} else /if (${Me.AltAbility[Group Perfected Invisibility]}) {
				/alt act ${Me.AltAbility[Group Perfected Invisibility]}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			}
		} else /if (${Me.Class.ShortName.Equal[SHM]}) {
			/if (${Me.AltAbility[Spirit Walk]}) {
				/alt act ${Me.AltAbility[Spirit Walk]}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			}
		} else /if (${Me.Class.ShortName.Equal[BST]}) {
			/if (${Me.AltAbility[Natural Invisibility]}) {
				/alt act ${Me.AltAbility[Natural Invisibility]}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			}
		} else /if (${Me.Class.ShortName.Equal[RNG]} || ${Me.Class.ShortName.Equal[DRU]}) {
			/if (${Me.AltAbility[Camouflage]}) {
				/alt act ${Me.AltAbility[Camouflage]}
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			
			}
		} else /if (${Me.Class.ShortName.Equal[ROG]}) {
			/if (${Me.AbilityReady[Hide]}) {
			/doability "Hide"
			/delay 1s
			}
			/if (${Me.AbilityReady[Sneak]}) {
			/doability "Sneak"
			} else /if (${FindItemCount[Cloudy Potion]}) {
				/casting "Cloudy Potion|Item"
			} else {
				/echo \ayYou are out of \at[\apCloudy Potions\at]\ay. \agFighting my way through if a group member doesn't have invis!
			
			}
		} else /if (${FindItemCount[Cloudy Potion]}) {
			/casting "Cloudy Potion|Item"
		}
		/if (${Debugging}) /echo Sub CheckInvis Exit
	}
	/if (${Debugging}) /echo Sub CheckInvis Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupDeathChk
| --------------------------------------------------------------------------------------------
Sub GroupDeathChk
	/if (${Debugging}) /echo Sub GroupDeathChk Entry
	|--- If ImDead
	/if (${Me.State.Equal[DEAD]}) {
		/echo \arYOU~ have died! Waiting for YOU to get off your face.
		|----------
		/while (${Me.State.Equal[DEAD]} ) {
			/call GMCheck
			/beep
			/beep
			/beep
			/delay 30			
		}
		|----------
	}
	|--- If ImDead
	/if (${Me.XTarget[1].ID}) /return
	|--- If Group --
	/if (${Group}) {
		/declare i int local
		|----------------------------------
		/for i 1 to ${Group}
			| -- If GroupMember IsDead
			/if (${Group.Member[${i}].State.Equal[DEAD]} ) {
				/echo ${Group.Member[${i}].Name} has died. Waiting for them to get off their face.
				|------   If No Target ID
				/if (!${Me.XTarget[1].ID}) {
					|----------------------------------
					/while (${Group.Member[${i}].State.Equal[DEAD]} && !${Me.XTarget[1].ID}) {
						/call GMCheck
						/if ((${Me.Standing}) && (!${Me.Casting.ID}) && (!${Me.Mount.ID})) /sit
						/beep
						/delay 30
					}
					/squelch /e3bcg /stand
				}
				|------   If No Target ID
			}
			| -- If GroupMember IsDead
		/next i
		|----------------------------------
	}
	|--- If Group --
	
	/if (${Debugging}) /echo Sub GroupDeathChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupManaChk
| --------------------------------------------------------------------------------------------
Sub GroupManaChk
	/if (${Debugging}) /echo Sub GroupManaChk Entry
	/if (${Me.XTarget[1].ID}) /return
	
	|------------------- If NoCombat	
	/if (!${Me.Combat}) {
		|---
		|--- If Me LowMana	
		/if ((${Me.PctMana} < ${MedAt} && !${Me.State.Equal[DEAD]} && !${Select[${Me.Class.ShortName},WAR,BER,ROG,MNK,BRD]}) || (${BardMed} && ${Me.PctMana} < ${MedAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
			/echo \arYOU are low on mana!
			|------   If No Target ID
			/if (!${Me.XTarget[1].ID}) {
				|--------------------------------------
				/while ((${Me.PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && !${Select[${Me.Class.ShortName},WAR,BER,ROG,MNK,BRD]}) || (${BardMed} && ${Me.PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
					/echo \agYour \am[\atMana\am]\ag is currently at \am[\at${Me.PctMana}\am]\ag%, medding to \am[\at${MedTill}\am]\ag%.
					/call GMCheck
					/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
					/delay 6s
				}
                /squelch /e3bcg /stand
			}
			|------   If No Target ID
		}
		|--- If Me LowMana
		|--- If Group --		
		/if (${Group}) {
			/declare i int local
			|--------------------------------------
			/for i 1 to ${Group}
				|------   If Valid GroupMemeber
				/if ((${Group.Member[${i}].PctMana} < ${MedAt} && ${Group.Member[${i}].Class.CanCast} && !${Group.Member[${i}].State.Equal[DEAD]} && !${Select[${Group.Member[${i}].Class.ShortName},BRD,WAR,MNK,BER,ROG]}) || (${BardMed} && (${Group.Member[${i}].PctMana} < ${MedAt}) && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
					/echo \ar${Group.Member[${i}].Name} is low on mana!
					|--------------
					| Make Them Sit
					|--------------
					/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
					|----					
					/call Refresh
					|------   If No Target ID
					/if (!${Me.XTarget[1].ID}) {
						|--------------------------------------
						/while ((${Group.Member[${i}].PctMana} < ${MedTill} && ${Group.Member[${i}].Class.CanCast} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && !${Select[${Group.Member[${i}].Class.ShortName},BRD,WAR,MNK,BER,ROG]}) || (${BardMed} && ${Group.Member[${i}].PctMana} < ${MedTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
							/echo \ag${Group.Member[${i}].CleanName}'s \am[\atMana\am]\ag is currently at \am[\at${Group.Member[${i}].PctMana}\am]\ag%, medding to \am[\at${MedTill}\am]\ag%.
							/call GMCheck
							/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
							/delay 3s
							|----------
							/if (${Group.Member[${i}].Standing}) {
								/delay 6s
								/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
							}							
							|----------
						}
						/squelch /e3bcg /stand
					}
					|------   If No Target ID
				}
				|------   If Valid GroupMemeber
			/next i
			|--------------------------------------
		}
		|--- If Group --
	}
	|------------------- If NoCombat
	
	/if (${Debugging}) /echo Sub GroupManaChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GroupEndChk
| --------------------------------------------------------------------------------------------
Sub GroupEndChk
	/if (${Debugging}) /echo Sub GroupEndChk Entry
	/if (${Me.XTarget[1].ID}) /return
	
	|------------------- If NoCombat
	/if (!${Me.Combat}) {
		|---
		|--- If Me LowEnd
		/if ((${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
			/echo \arYOU are low on Endurance!
			|------   If No Target ID
			/if (!${Me.XTarget[1].ID}) {
				|--------------------------------------
				/while ((${Me.PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Me.PctEndurance} < ${MedEndAt} && !${Me.State.Equal[DEAD]} && ${Me.Class.ShortName.Equal[BRD]})) {
					/echo \agYour \am[\atEndurance\am]\ag is currently at \am[\at${Me.PctEndurance}\am]\ag%, medding to \am[\at${MedEndTill}\am]\ag%.
					/call GMCheck
					/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
					/delay 6s
				}
                /squelch /e3bcg /stand
			}
			|------   If No Target ID
		}
		|--- If Me LowEnd
		|--- If Group --
		/if (${Group}) {
			/declare i int local
			|--------------------------------------
			/for i 1 to ${Group}
				|------   If Valid GroupMemeber
				/if (${Group.Member[${i}].ID}) {
					|------   If GroupMember LowEnd
					/if ((${Group.Member[${i}].PctEndurance} < ${MedEndAt} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Group.Member[${i}].PctEndurance} < ${MedEndAt} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
						/echo \ar${Group.Member[${i}].Name} is low on Endurance!
						|--------------
						| Make Them Sit
						|--------------
						/squelch /e3bct ${Group.Member[${i}].CleanName} /sit
						/call Refresh
						|------   If No Target ID
						/if (!${Me.XTarget[1].ID}) {
							|---------------------------------------
							/while ((${Group.Member[${i}].PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.NotEqual[BRD]}) || (${BardMed} && ${Group.Member[${i}].PctEndurance} < ${MedEndTill} && !${Me.XTarget[1].ID} && !${Group.Member[${i}].State.Equal[DEAD]} && ${Group.Member[${i}].Class.ShortName.Equal[BRD]})) {
								/echo \ag${Group.Member[${i}].CleanName}'s \am[\atEndurance\am]\ag is currently at \am[\at${Group.Member[${i}].PctEndurance}\am]\ag%, medding to \am[\at${MedEndTill}\am]\ag%.
								/call GMCheck
								/if (${Me.Standing} && !${Me.Casting.ID} && !${Me.Mount.ID} && !${Navigation.Active}) /sit
								/delay 3s
								|----------
								/if (${Group.Member[${i}].Standing}) {
									/delay 6s
									/squelch /e3bct ${Group.Member[${i}].CleanName} /sit							
								}							
								|----------
						}
						|---------------------------------------
						/squelch /e3bcg /stand
						}
						|------   If No Target ID
					}
					|------   If GroupMember LowEnd
				}
				|------   If Valid GroupMemeber
			/next i
			|--------------------------------------
		}
		|--- If Group --
	}
	|------------------- If NoCombat
	
	/if (${Debugging}) /echo Sub GroupEndChk Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Refresh
| --------------------------------------------------------------------------------------------
Sub Refresh
/if (${Debugging}) /echo Sub Refresh Entry
/if (${Debugging}) /echo Calling Refresh
	/keypress F2
	/delay 2s
	/keypress F3
	/delay 2s
	/keypress F4
	/delay 2s
	/keypress F5
	/delay 2s
	/keypress F6
	/delay 2s
	/squelch /target clear
	/if (${Debugging}) /echo Sub Refresh Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: GetExpeditionData
| --------------------------------------------------------------------------------------------
Sub GetExpeditionData
	/if (${Debugging}) /echo Sub GetExpeditionData Entry
		|--------------------------------------------
		:OpenDynamicZoneWindow
		|--- open the Expedition Window to pull data
		/keypress alt+z
		/delay 1s
		/delay 3s ${Window[DynamicZoneWnd].Open}
		/if (!${Window[DynamicZoneWnd].Open}) /goto :OpenDynamicZoneWindow
		|--------------------------------------------------------------
		|-- Determine if I have a Dranik Catacombs Expedition Assigned.
		|--------------------------------------------------------------
		/varset CurrentExpedition ${Window[DynamicZoneWnd].Child[DZ_CurrentDZValue].Text}
		|--------------------------
		/if (!${CurrentExpedition.Length}==0 && ${CurrentExpedition.Find[Catacombs of Dranik]}) {
			/varset DranikCExpedition 1
		} else {
			/varset DranikCExpedition 0
		}	
		|--------------------------
		/keypress alt+z
		|--------------------------------------------
	/if (${Debugging}) /echo Sub GetExpeditionData Exit
/return
| --------------------------------------------------------------------------------------------	

| --------------------------------------------------------------------------------------------
| SUB: CheckInADungeon
| --------------------------------------------------------------------------------------------
Sub CheckInADungeon
	/if (${Debugging}) /echo Sub CheckInADungeon Entry
	/if (${Select[${Zone.ID},330]}) {
		/varset InADungeon 1
	} else {
		/varset InADungeon 0
	}
	/if (${Debugging}) /echo Sub CheckInADungeon Exit
/return
| --------------------------------------------------------------------------------------------	

| --------------------------------------------------------------------------------------------
| SUB: CheckHaveDranikCExp
| --------------------------------------------------------------------------------------------
Sub CheckHaveDranikCExp
	/if (${Debugging}) /echo Sub CheckHaveDranikCExp Entry
	
	|--------------------------------------------------------------
	|-- Determine if I have a Dranik Catacombs Expedition Assigned.
	|--------------------------------------------------------------
	/varset CurrentExpedition ${Window[DynamicZoneWnd].Child[DZ_CurrentDZValue].Text}
	|--------------------------
	/if (!${CurrentExpedition.Length}==0 && ${CurrentExpedition.Find[Catacombs of Dranik]}) {
		/varset DranikCExpedition 1
	} else {
		/varset DranikCExpedition 0
	}	
	|--------------------------
		
	/if (${Debugging}) /echo Sub CheckHaveDranikCExp Exit
/return
| --------------------------------------------------------------------------------------------	

| --------------------------------------------------------------------------------------------
| SUB: CheckINI
| --------------------------------------------------------------------------------------------
Sub CheckINI(string IniName,string Section,string Key,string TypeVar,Default)
    /if (${Debugging}) /echo (IniName:${IniName} Section:${Section} Key:${Key} TypeVar:${TypeVar})
	/if (${Debugging}) /echo Sub CheckINI Entry
	/if (!${Ini[${IniName},${Section},${Key}].Length}) {
		/ini ${IniName} ${Section} ${Key} ${Default}
	}
	/declare ${Key} ${TypeVar} outer ${Ini[${IniName},${Section},${Key}]}
	/echo \atLoading \ayINI \ay[\am${IniName}\ay] \ar~ \aoKey: \ag${Key} \aoType: \ag${TypeVar} \aoINI Value: \at\ay[\am${Ini[${IniName},${Section},${Key}]}\ay]
	/if (${Debugging}) /echo Sub CheckINI Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckThings
| --------------------------------------------------------------------------------------------
Sub CheckThings
	/if (${Debugging}) /echo Sub CheckThings Entry
	
	/call CheckPlugin MQ2Nav
	/call CheckMesh
	/call CheckPlugin MQ2Events
	|-----------------------------
	/if (${UseMq2Melee}) {
		/call CheckPlugin MQ2Melee
	} else {
		/if (${Bool[${Plugin[MQ2Melee]}]}) {
			/echo \ay -- Unloading \am[\atMQ2Melee\am]\ay plugin.
			/squelch /plugin MQ2Melee unload noauto
		}
	}
	|-----------------------------
	/call CheckPlugin MQ2MoveUtils

	|----------------------
	/if (${Bool[${Plugin[MQ2Bucles]}]}) {
        /squelch /plugin MQ2Bucles unload noauto
        /echo MQ2Bucles detected! This macro doesn't like it! Unloading temporarily ...
    }	
	|----------------------	
	
	/if (${LootCorpse}) {
		/message ==================================================================
		/message \ay--- ENABLING ${MacroName} LOOTING, we will only loot [\atDiamond Coin\ay] 
		/message        if configured in your E3 \agLoot Settings.ini\ax
		/message ==================================================================
		/squelch /looton
	} else {
		/message ==================================================================
		/message \ar--- DISABLING ${MacroName} LOOTING, YOU WILL NOT LOOT CORPSES !
		/message ==================================================================
		/squelch /lootoff
	}
	
	/if (${Endmac}) /end
	/if (${Debugging}) /echo Sub CheckThings Exit
	
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckMesh  ( Called from CheckThings )
| --------------------------------------------------------------------------------------------
Sub CheckMesh
	/if (${Debugging}) /echo Sub CheckMesh Entry
	/if (!${Navigation.MeshLoaded}) {
		/nav reload
		/delay 3s ${Navigation.MeshLoaded}
		/if (!${Navigation.MeshLoaded}) {
			/echo "\arNo navigational mesh could be found for this zone. Make one and try again"
			/varset Endmac TRUE
		}
	}
	/if (${Debugging}) /echo Sub CheckMesh Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: CheckPlugin
| --------------------------------------------------------------------------------------------
  Sub CheckPlugin(string pluginname)
  /if (${Debugging}) /echo Sub CheckPlugin Entry
  	
	|------------
	/if (!${Bool[${Plugin[${pluginname}]}]} && !${pluginname.Equal[E3BCS]}) {
		/echo \ag${pluginname}\ax \arNOT\ax detected! This macro requires it! Loading ...
		/squelch /plugin ${pluginname}
		/if (!${Bool[${Plugin[${pluginname}]}]}) {
			/echo \ag${pluginname}\ax \arSTILL NOT\ax detected! This macro requires it! EXITING ...
			/endmacro
		} else {
		    /echo \ag${pluginname}\ax \atNOW\ax detected !
		}
	} else {
		/echo \ag${pluginname}\ax detected!
	}
	|------------
		
	/if (${Debugging}) /echo Sub CheckPlugin Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: ReclaimAltDC
| --------------------------------------------------------------------------------------------
Sub ReclaimAltDC
 /if (${Debugging}) /echo Sub ReclaimAltDC Entry

	/varset CurrentDC ${FindItemCount[=Diamond Coin]}
	/varset CurrentDCAC ${Me.AltCurrency[20]} 
	/echo \ayDiamond Coin: Alternate Currency=(\at${CurrentDCAC}\ay) | Inventory=(\at${CurrentDC}\ax)

	|-----------------------------------------------
	/if (${CurrentDC}>0) {	
		; --- If I have DC in inventory, RECLAIM it to Alternate Currency !!!  
		/echo \ag$$$\ay I have [\atDiamond Coin\ay]  to reclaim!\ax
	
		; Open the Inventory Window if it is closed
		|----------------------------------------------
		/if (!${Window[InventoryWindow].Open}) /call OpenInvWindow
		|----------------------------------------------	
	
		; Select Alt Currency Tab
		/if (${Debugging}) /echo Selecting Alt Currency Tab
		/if (!${Window[InventoryWindow].Child[IW_AltCurrPage].Open})  /notify InventoryWindow IW_Subwindows tabselect 5
		/delay 5
	
		; Select Diamond Coin off the Alternate Currecy tab in Inventory window ..  YOU NEED TO OPEN INVENTORY WINDOW FOR THIS ! 
		/if (${Debugging}) /echo Selecting Diamond Coins
		/notify InventoryWindow IW_AltCurr_PointList listselect 2
		/delay 5

		; Click the RECLAIM BUTTON after selecting Diamond Coin previously
		/nomodkey /notify InventoryWindow AltCurr_ReclaimButton LeftMouseUp
		/delay 5
	} else {
	    ; --- If I have NO DC in inventory to RECLAIM
		/echo \ag$$$\ay I have \arNO\ay [\atDiamond Coin\ay] to reclaim!\ax
	}
	|-----------------------------------------------
	; Update the DC and Alternate DC Currency ammount.
	/varset CurrentDC ${FindItemCount[=Diamond Coin]}
	/varset CurrentDCAC ${Me.AltCurrency[20]} 
	/echo \ayDiamond Coin: Alternate Currency=(\at${CurrentDCAC}\ay) | Inventory=(\at${CurrentDC}\ax)
	; Close the Inventory Window if it is open
	|----------------------------------------------
	/if (${Window[InventoryWindow].Open}) /call CloseInvWindow
	|----------------------------------------------	

	/if (${CurrentDC}==0) /echo \ag$$$ \ayAll available DC was converted to Alternate Currency !

/if (${Debugging}) /echo Sub ReclaimAltDC Exit

/return
