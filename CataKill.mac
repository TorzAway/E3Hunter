|--------------------------------------------------------
  Sub Event_BagsFull
  /echo \ay*** Bags are full, time to sell ! ***\ax

 |----------------------------------------------
/if (${Me.AltAbilityReady[Summon Agent]}) {
	/echo \ag$$$\ax \aoSummoning:\ax \atResupply Agent\ax \ayto AutoSell.\ax \ag$$$\ax
	/alt act ${Me.AltAbility[Summon Resupply Agent].ID}
	/delay 1s
	|-----------------------------------
	/if (!${Window[MerchantWnd].Open}) {
		:TargetAgent		
		/squelch /target Merchant
		/delay 2s ${Target.ID}
		/if (!${Window[MerchantWnd].Open}) /goto :TargetAgent
		|-------------------------------------
		/if (${Target.ID}) {
			/squelch /nav id ${Target.ID} 
			/delay 5
			/while (${Navigation.Active}) {
				/call SetLoc
				/call CheckStuck
				/delay 5
			}	
		}
		/delay 5
		|-------------------------------------
	
		|------------------
		/call ReclaimAltDC
		|------------------
	
		|-------------------------------------
		/if (${Target.ID} && ${Target.Distance}<=20) {
			/nomodkey /click right target
			/delay 5s ${Window[MerchantWnd].Open}
			/echo \ay Attempting to \amAutoSell\ax now.
			/delay 1s
			/call OpenPacks
			/delay 1s
			/autosell
			|-----------------
			/while (${Window[MerchantWnd].Open}) {		
				/delay 5
			}
			|-----------------
			/call ClosePacks
			/delay 1s
		}
		|-------------------------------------	
		
	}
	|-----------------------------------
} else {
	/echo \aoYour\ax \atResupply Agent\ax \aois not available for AutoSell !\ax
	/delay 1s
}
 |----------------------------------------------
  /return
