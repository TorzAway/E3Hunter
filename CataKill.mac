| --------------------------------------------------------------------------------------------
| SUB: GoToDranikFromMarr
| --------------------------------------------------------------------------------------------
Sub GoToDranikFromMarr
/if (${Debugging}) /echo Sub GoToDranik Entry
	
|------------------------------
/if (${Zone.ID} == ${TempleofMarr}) {
	/echo \ayI am headed to \am[\atThe Ruined City of Dranik\am]\ay.\ax
	/delay 3s	
	|----------------------------
	/while (${Group.Member[1].OtherZone} || ${Group.Member[2].OtherZone} || ${Group.Member[3].OtherZone} || ${Group.Member[4].OtherZone} || ${Group.Member[5].OtherZone} || ${Group.Member[6].OtherZone}) {
		|--- Group - Start in Marrs	
		/delay 10
		/squelch /e3bca /nav stop
		/squelch /e3bca /playmelody stop
		/squelch /e3bca /keypress x 
		/delay 6
		/squelch /e3bcaa /stand
		/delay 5
		/squelch /e3bca /alt act 511
		
		|---  Now Me !
		/nav stop
		/if (${Select[${Me.Class.ShortName},BRD]}) /playmelody stop
		/keypress x 
		/delay 6
		/stand
		/delay 5
		/alt act 511
		/delay 20s
	}
	|----------------------------
	/squelch /e3bcaa /tar Klonopin
	/delay 5
	/squelch /e3bcaa /nav target
	/delay 5
	/while (${Navigation.Active}) {
		/call SetLoc
		/call CheckStuck
		/delay 5
	}
	/call GroupWait
	/delay 2s	
	/bark dranik
	/delay 2s
}
|------------------------------
|---------------
/while (${Zone.ID} != ${RuinedCityofDranik}) {
	/delay 5s
}
|---------------
/call GroupWait
/delay 2s

/if (${Zone.ID} == ${RuinedCityofDranik}) /echo \ayI am currently in \am[\atThe Ruined City of Dranik\am]\ay.\ax
/call GotoRecruiter	

/if (${Debugging}) /echo Sub GoToDranik Exit
/return
