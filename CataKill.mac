| --------------------------------------------------------------------------------------------
| SUB: DoSwarmPull_MainLoop_Bigger		Note: Define The Array Variables and kick off Go2LastSwarmLoc
| --------------------------------------------------------------------------------------------
Sub DoSwarmPull_MainLoop_Bigger
/if (${Debugging}) /echo Sub DoSwarmPull_MainLoop_Bigger Entry

/message \agSetting up pathing to \ay[\arSwarm Pull\ay] \agdungeon. . . . . 
/message ==================================================================

|---------------------------------------------------------
| Delete any EXISTING LocalStepArray
|---------------------------------------------------------
/if (${Defined[LocalStepArray_${Zone.ShortName}_2]}) {
	/echo \arDeleting \atOLD \aydungeon array\ar \am[\atLocalStepArray_${Zone.ShortName}_2\am]\ax
	/deletevar LocalStepArray_${Zone.ShortName}_2
}
|---------------------------------------------------------

|------------------------1: CataCombC 
	/echo \atLoading steps for: \ay[Catacombs of Dranik (Caza)]\at.
	|------------------------------------------------------
	|  Define The Array Variables so the dungeon can be Run
	|------------------------------------------------------
	|------------------------------------------------------
	/echo \ayCreating dynamic dungeon array.
	/if (!${Defined[LocalStepArray_${Zone.ShortName}_2]}) {
		/echo \ayCreating \am[\atLocalStepArray_${Zone.ShortName}_2[1,6]\am]\ax
		/declare LocalStepArray_${Zone.ShortName}_2[1,6]	string	outer
		/delay 10
	}
	|------------------------------------------------------
	
	|---------------------------------- MAIN CYCLE BELOW
	|---------------------------------- LEFT BOTTOM
	/varset LocalStepArray_${Zone.ShortName}_2[1,1] 2016.83 711.16 -135.32
	|---------------------------------- LEFT BOTTOM
	|---------------------------------- LEFT MIDDLE
	/varset LocalStepArray_${Zone.ShortName}_2[1,2] 2247.83 711.16 -135.32
	|---------------------------------- LEFT MIDDLE
	|---------------------------------- LEFT TOP
	/varset LocalStepArray_${Zone.ShortName}_2[1,3] 2449.70 711.16 -135.32
	|---------------------------------- LEFT TOP
	|---------------------------------- RIGHT TOP	    
	/varset LocalStepArray_${Zone.ShortName}_2[1,4] 2449.70 -68.40 -135.32
	|---------------------------------- RIGHT TOP
	|---------------------------------- RIGHT MIDDLE
	/varset LocalStepArray_${Zone.ShortName}_2[1,5] 2228.83 -68.40 -135.32
	|---------------------------------- RIGHT MIDDLE
	|---------------------------------- RIGHT BOTTOM
	/varset LocalStepArray_${Zone.ShortName}_2[1,6] 2007.83 -68.40 -135.32
	|---------------------------------- RIGHT BOTTOM
	|---------------------------------- MAIN CYCLE ABOVE	
	
	|------------------------------------------------------
	/echo \ayStep \am[\ag1\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,1]}\am]\ay
	/echo \ayStep \am[\ag2\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,2]}\am]\ay
	/echo \ayStep \am[\ag3\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,3]}\am]\ay
	/echo \ayStep \am[\ag4\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,4]}\am]\ay
	/echo \ayStep \am[\ag5\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,5]}\am]\ay
	/echo \ayStep \am[\ag6\am]\ay set to \am[\ag${LocalStepArray_${Zone.ShortName}_2[1,6]}\am]\ay
	/message ==================================================================
	|----------------------------------------------------
	/echo \agGet ready, the fun is starting soon !
	/delay 5
	/Call DoClearTargets
	/delay 10	
	|- Call Go2LastSwarmLoc after Defining Array
	/call Go2LastSwarmLoc
	|------------
 }
|------------------------1: CataCombC

/if (${Debugging}) /echo Sub DoSwarmPull_MainLoop_Bigger Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: NavToLoc -- [NO Combat and Agro Aware movement]
| --------------------------------------------------------------------------------------------
Sub NavToLoc(int Y,int X,int Z)
	/if (${Debugging}) /echo Entering Sub NavToLoc for ${Y} ${X} ${Z} at Line: ${Macro.CurLine}
	/varset GroupWaitTimer 0
	|-------------------------------------------------------------------------------
	/while (${Math.Distance[${Me.Y}, ${Me.X}, ${Me.Z}: ${Y}, ${X}, ${Z}]} > 30) {
		/if (${Navigation.Active}) {
			/if (${CheckBots}) /call GroupDeathChk
			/if (${CheckBots}) /call GroupManaChk
			/if (${CheckBots}) /call GroupEndChk
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL DoSinglePull NavToLoc
				/call DoSinglePull
			} else {
				/if (${CheckBots}) /call GroupDeathChk
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL FARM STUFF NavToLoc II
				/call DoSinglePull
			} else {
				/if (${CheckBots}) /call GroupDeathChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${Me.Moving}) /nav loc ${Y} ${X} ${Z}
			/delay 5 ${Me.Moving}
			/delay 5 ${Navigation.Active}			
		}
	}
	|-------------------------------------------------------------------------------
	/delay 2s
	|/if (${Navigation.Active}) /nav stop
	/if (${Debugging}) /echo Sub NavToLoc Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: NavToLoc2 -- [Combat and Agro Aware movement]
| --------------------------------------------------------------------------------------------
Sub NavToLoc2(int Y,int X,int Z)
	/if (${Debugging}) /echo Entering Sub NavToLoc2 for ${Y} ${X} ${Z} at Line: ${Macro.CurLine}
	/varset GroupWaitTimer 0
	/while (${Math.Distance[${Me.Y}, ${Me.X}, ${Me.Z}: ${Y}, ${X}, ${Z}]} > 20) {
		/if (${Navigation.Active}) {
			/if (${Debugging}) /echo WaitNav Moving ELSE
			/if (${CheckBots}) /call GroupDeathChk			
			/if (${CheckBots}) /call GroupManaChk
			/if (${CheckBots}) /call GroupEndChk
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL DoSinglePull NavToLoc
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/call DoClearTargets
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			} else {
				/if (${Debugging}) /echo WaitNav Moving ELSE
				/if (${CheckBots}) /call GroupDeathChk				
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL FARM STUFF NavToLoc II
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/call DoClearTargets
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			} else {
				/if (${CheckBots}) /call GroupDeathChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${Me.Moving} && !${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /e3bcaa /nav loc ${Y} ${X} ${Z}
			/delay 5 ${Me.Moving}
			/delay 5 ${Navigation.Active}
		}
	}
	/delay 2s
	|/if (${Navigation.Active}) /nav stop
	/if (${Debugging}) /echo Sub NavToLoc2 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: NavToLoc3 - [Combat and Agro Aware movement - with invis recheck]
| --------------------------------------------------------------------------------------------
Sub NavToLoc3(int Y,int X,int Z)
	/if (${Debugging}) /echo Entering Sub NavToLoc2 for ${Y} ${X} ${Z} at Line: ${Macro.CurLine}
	/varset GroupWaitTimer 0
	/while (${Math.Distance[${Me.Y}, ${Me.X}, ${Me.Z}: ${Y}, ${X}, ${Z}]} > 20) {
		/if (${Navigation.Active}) {
			/if (${Debugging}) /echo WaitNav Moving ELSE
			/if (${CheckBots}) /call GroupDeathChk			
			/if (${CheckBots}) /call GroupManaChk
			/if (${CheckBots}) /call GroupEndChk
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL DoSinglePull NavToLoc
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/call Group2Me
				/call DoClearTargets
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			} else {
				/if (${Debugging}) /echo WaitNav Moving ELSE
				/if (${CheckBots}) /call GroupDeathChk				
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/if (${Debugging}) /echo CALL FARM STUFF NavToLoc II
				/target ${Me.XTarget[1].ID}
				/if (${Spawn[id ${Target.ID}].Distance} > 30) /squelch /nav id ${Target.ID}
				/if (${Spawn[id ${Target.ID}].Distance} < 30) {
				/if (${Target.ID}) /face
				/if (${Bool[${Plugin[MQ2Melee]}]}) /squelch /killthis
				/squelch /attack on
				/call Group2Me
				/call DoClearTargets
				/doevents
				/if (${UseClickDamage}) /call Clickies_Damage
			}
			} else {
				/if (${CheckBots}) /call GroupDeathChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${Me.Combat} && !${Me.XTarget[1].ID})  /call CheckInvis
			/if (!${Me.Moving} && !${Me.Combat} && !${Me.XTarget[1].ID} && ${Me.Invis}) /squelch /e3bcaa /nav loc ${Y} ${X} ${Z}
			/delay 5 ${Me.Moving}
			/delay 5 ${Navigation.Active}
		}
	}
	/delay 2s
	|/if (${Navigation.Active}) /nav stop
	/if (${Debugging}) /echo Sub NavToLoc2 Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: WaitNav
| --------------------------------------------------------------------------------------------
Sub WaitNav(NavTargetID)
	/if (${Debugging}) /echo \agEntering Sub WaitNav for ${Spawn[id ${NavTargetID}].Y} ${Spawn[id ${NavTargetID}].X} ${Spawn[id ${NavTargetID}].Z} at Line: ${Macro.CurLine}
	/if (!${Spawn[id ${NavTargetID}].ID}) {
		/delay 5s
		/return
	}
	/while (${Spawn[id ${NavTargetID}].Distance} > ${If[${PullAbilityRange},${PullAbilityRange},30]} || !${Spawn[${myTargetID}].LineOfSight}) {
		/if (!${Spawn[id ${NavTargetID}].ID}) {
			/delay 5s
			/return
		}
		/if (${Spawn[id ${NavTargetID}].Distance} < 30) {
			/nav stop
		}
		/if (${Spawn[id ${NavTargetID}].ID}) {
			/call SetLoc
			/call CheckStuck
			/call GMCheck
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/varset NavTargetID ${Me.XTarget[1].ID}
				/if (${Debugging}) /echo CALL FARM STUFF WaitNAV
				/call DoSinglePull
			} else {
				/if (${Debugging}) /echo \ayWaitNav Moving
				/if (${CheckBots}) /call GroupDeathChk				
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
				/call GMCheck
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/if (!${courseCorrection}) {
				|------  ALL GO TO TARGET - staggered
				/nav id ${NavTargetID}	
				/delay 5
				/squelch /e3bca /nav id ${NavTargetID}				
				|------  ALL GO TO TARGET - staggered
				/varset courseCorrection ${courseCorrection.OriginalValue}
			}
			/if (${GroupNavToMe}) {
                /call Group2Me
            }
			/delay 10
		} else {
			/if (${Me.XTarget[1].ID}) {
				/if (${Navigation.Active}) /nav stop
				/e3bcaa /target id ${Me.XTarget[1].ID}
				/varset NavTargetID ${Me.XTarget[1].ID}
				/if (${Debugging}) /echo CALL DoSinglePull WaitNav II
				/call DoSinglePull
			} else {
				/varcalc BackUpTimer (${BackUpTimer})+1
				/if (${BackUpTimer}>7) {
					/echo \ayHaving trouble getting to a target.. Attempting to get back on mesh.
					/if (${Debugging}) /echo Setting BackUpTimer Plus 1
					/call BackUp
					/varset BackUpTimer 0
					/varset NavTargetID 0
					/if (${Me.XTarget[1].ID}) {
						/varset NavTargetID ${Me.XTarget[1].ID}
					}
				}
				/if (${Debugging}) /echo WaitNav Moving ELSE
				/if (${CheckBots}) /call GroupDeathChk				
				/if (${CheckBots}) /call GroupManaChk
				/if (${CheckBots}) /call GroupEndChk
			}
			/if (${Me.Combat} && !${Me.XTarget[1].ID}) /squelch /target clear
			/squelch /nav id ${NavTargetID}
		}
	}
	/if (${Navigation.Active}) /nav stop
	:target
	/target id ${NavTargetID}
	/delay 2s ${Target.CleanName.Equal[${Spawn[id ${NavTargetID}].CleanName}]}
	/if (!${Target.CleanName.Equal[${Spawn[id ${NavTargetID}].CleanName}]} && ${Spawn[id ${NavTargetID}].ID} && !${Me.XTarget[1].ID}) {
		/goto :target
	}
	/if (${Debugging}) /echo Sub WaitNav Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: Zoning
| --------------------------------------------------------------------------------------------
Sub Zoning
	/if (${Debugging}) /echo Sub Zoning Entry
	:Zoning
	/delay 2m ${Zone.ID}!=${startZone}
	/target id ${Me.ID}
	/delay 1s ${Target.ID}==${Me.ID}
	/if (!${Navigation.MeshLoaded}) {
		/echo \ayWaiting for you to load a mesh for this zone.
		/nav reload
		/delay 5s
		/goto :Zoning
	}
	/delay 2s
	/varset startZone ${Zone.ID}
	/squelch /target clear
	/call CheckMesh
	/delay 2s
	|---------------------------------------------
	| Cleartargets if I have agro on zoning.
	|---------------------------------------------
	/if (${Me.XTarget[1].ID}) /Call DoClearTargets
	/call Refresh
	/if (${Debugging}) /echo Sub Zoning Exit
/return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: CheckForCorpses
| --------------------------------------------------------------------------------------------
  Sub CheckForCorpses
  /if (${Debugging}) /echo Sub CheckForCorpses Entry

  /call GMCheck
  /hidecorpse looted

:CheckAgain
  /echo \ay- Checking for missed corpse(s).
  /squelch /target radius 100 corpse
  /delay 5 ${Target.ID}

  /if (${Target.ID} && ${Target.Type.Equal[Corpse]}) {
    /echo \at+++ \ayLooks like we have a corpse to loot!\ax
    /if (${Target.ID}) /face nolook
	
	|----------------------------------------------	
	|-----
	/if (${Navigation.PathExists[id ${Target.ID}]}) {
		/if (${Target.ID} && !${Me.Casting.ID}) /nav id ${Target.ID} 
	} else {
		 /if (${Target.ID} && !${Me.Casting.ID}) /moveto id ${Target.ID} mdist 10	
	}
	|-----
    |----------------------------------------------	
	
	|-------------------------
	/call CheckCasting
	/delay 5 !${Me.Moving}
	|-------------------------
	/if (!${Me.XTarget[1].ID} && !${Me.Casting.ID} && !${Me.Moving}) /call LootMob_E3
	|-------------------------
	
    /squelch /target clear
    /goto :CheckAgain
  } else {
    /echo \ar+++ \ayNo corpse(s) found to loot.\ax
  }

	/if (${Debugging}) /echo Sub CheckForCorpses Exit
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
|SUB: LootMob_E3 -- Let E3 Looting handle your corpseloot.
| --------------------------------------------------------------------------------------------
  Sub LootMob_E3
	/if (${Debugging}) /echo Sub LootMob_E3 Entry  
	
	/if (${Target.ID}) /face nolook
	/keypress forward
	/keypress back
	/fastdrop on
	/lootn never
	/delay 1s
	|---------------------------------------
	| -- Let E3 Looting System handle this !
	|---------------------------------------	
	/loot
	|---------------------------------------
	| -- Let E3 Looting System handle this !
	|---------------------------------------
	/delay 1s
	/doevents
	
	/if (${Debugging}) /echo Sub LootMob_E3 Exit  
  /return
| --------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: OpenPacks
| --------------------------------------------------------------------------------------------
	Sub OpenPacks
	/declare bag int local 0
	/if (!${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s ${Window[InventoryWindow].Open}
	/for bag 1 to 10
		/if (!${Window[Pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
		/delay 3s ${Window[Pack${bag}].Open}
		/if (${Window[TradeskillWnd].Open}) /nomodkey /notify TradeskillWnd ExperimentButton leftmouseup
		/delay 5s !${Window[TradeskillWnd].Open}
	/next bag
	/return
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: ClosePacks
| --------------------------------------------------------------------------------------------
	Sub ClosePacks
	/declare bag int local 0
	/if (!${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s ${Window[InventoryWindow].Open}
	/for bag 1 to 10
		/if (${Window[Pack${bag}].Open}) /nomodkey /itemnotify pack${bag} rightmouseup
		/delay 3s !${Window[Pack${bag}].Open}
	/next bag
	/if (${Window[InventoryWindow].Open}) /nomodkey /keypress inventory
	/delay 3s !${Window[InventoryWindow].Open}
  /return
|--------------------------------------------------------------------------------------------

| --------------------------------------------------------------------------------------------
| SUB: DoorClick
| --------------------------------------------------------------------------------------------
Sub DoorClick 
/if (${Debugging}) /echo Sub DoorClick Entry
	/doortarget
	/delay 1s
	/click left door
/if (${Debugging}) /echo Sub DoorClick Exit	
/return 
| --------------------------------------------------------------------------------------------

|--------------------------------------------------------
|Group2Me
|--------------------------------------------------------
Sub Group2Me
/if (${Debugging}) /echo Sub Group2Me Entry
	/e3bca /nav id ${Me.ID}
/if (${Debugging}) /echo Sub Group2Me Exit
/return
